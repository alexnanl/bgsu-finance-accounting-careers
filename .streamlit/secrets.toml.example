# Copy this file to `.streamlit/secrets.toml` and fill in your real values.
# DO NOT commit secrets.toml to git — it is listed in .gitignore.

# Required: OpenAI API key (used to standardize raw postings).
OPENAI_API_KEY = "sk-your-openai-api-key-here"

# Required: password for the Admin / Editor page.
# Choose a long, hard-to-guess value. Anyone with this password can add,
# edit, and delete postings.
ADMIN_PASSWORD = "change-me-to-a-strong-password"

# Optional: override the default OpenAI model.
# OPENAI_MODEL = "gpt-4o-mini"
